OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SUPERVISOR_ENABLED=true
ALERT_EMAIL=
GMAIL_APP_PASSWORD=
RAILWAY_DATABASE_URL=
ASSET_BASE_URL=

# 사진 영구 저장 (Railway Volume). 미설정 시 카카오 CDN URL 그대로 저장 (만료 위험).
# PHOTO_VOLUME_PATH       Railway Volume 마운트 경로 (Railway 대시보드에서 /data 로 마운트)
# PHOTO_PUBLIC_BASE_URL   chatbot 도메인 + /photos. 예: https://chatbot-production-xxx.up.railway.app/photos
PHOTO_VOLUME_PATH=/data/photos
PHOTO_PUBLIC_BASE_URL=
