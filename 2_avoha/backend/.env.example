# 아보하 백엔드 환경변수 템플릿 (FastAPI)
# 로컬에선 `.env` 로 복사해 값을 채워 사용.

ENV=development

# --- Kakao Developers (developers.kakao.com) ---
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback

# --- DB / Queue (로컬: docker-compose 기본값) ---
DATABASE_URL=postgresql+asyncpg://avoha:avoha_dev@localhost:5432/avoha
REDIS_URL=redis://localhost:6379

# --- Auth / 세션 ---
# 세션 쿠키 서명 키 (32바이트 hex = 64자). 생성: openssl rand -hex 32
SESSION_SECRET=

# --- 프론트엔드 (CORS allow_origin, OAuth callback redirect 대상) ---
FRONTEND_URL=http://localhost:5173

# --- Kakao 채널 / 상담톡 웹훅 공유 비밀 ---
# 미설정 시 X-Avoha-Webhook-Secret 검증 생략.
# KAKAO_WEBHOOK_SECRET=

# --- 운영 콘솔 허용 Kakao ID (쉼표 구분) ---
OPS_ALLOWED_KAKAO_IDS=

# --- 운영 알림 (Discord Webhook) ---
# DISCORD_OPS_WEBHOOK=

# --- 에러 추적 (Sentry) ---
# SENTRY_DSN 이 설정되면 자동 초기화, 미설정이면 noop.
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
